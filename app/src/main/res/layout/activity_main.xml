<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText android:id="@+id/etNombre" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombres" android:enabled="false"/>
    <EditText android:id="@+id/etApellido" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Apellidos" android:enabled="false"/>
    <EditText android:id="@+id/etNumeroUno" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Numero Uno" android:enabled="false"/>
    <EditText android:id="@+id/etNumeroDos" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Numero Dos" android:enabled="false"/>
    <EditText android:id="@+id/etMultiplicacion" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Multiplicación" android:enabled="false"/>
    <EditText android:id="@+id/etPotencia" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Potencia" android:enabled="false"/>
    <EditText android:id="@+id/etFactorial" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Factorial" android:enabled="false"/>

    <Button android:id="@+id/btnSiguiente" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Siguiente"/>
    <Button android:id="@+id/btnResultados" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mostrar Resultados" android:enabled="false"/>
</LinearLayout>