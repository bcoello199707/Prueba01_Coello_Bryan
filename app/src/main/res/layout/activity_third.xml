<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText android:id="@+id/etNombre3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombres" android:enabled="false"/>
    <EditText android:id="@+id/etApellido3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Apellidos" android:enabled="false"/>
    <EditText android:id="@+id/etNumeroUno3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Numero Uno" android:inputType="numberSigned"/>
    <EditText android:id="@+id/etNumeroDos3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Numero Dos" android:inputType="numberSigned"/>

    <Button android:id="@+id/btnCerrar3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cerrar"/>
</LinearLayout>